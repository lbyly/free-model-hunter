"""
Free Models Hub 环境变量配置
复制此文件为 .env 并填入你的 API Keys（非必须，没有 API Key 的 Provider 会使用已知模型降级）
"""

# 数据库路径（默认使用 data/models.db）
DATABASE_URL=d:/TEST/data/models.db

# 爬虫定时（北京时间 24h 格式）
SCHEDULE_HOURS=2,14

# 爬虫 HTTP 请求超时（秒）
SCRAPER_TIMEOUT=30

# ===== API Keys（可选配置） =====

# Groq API Key（免费申请：https://console.groq.com/keys）
GROQ_API_KEY=

# Cohere API Key
COHERE_API_KEY=

# MiniMax API Key
MINIMAX_API_KEY=

# 阿里云百炼 API Key
ALIBABA_API_KEY=

# Google Gemini API Key
GEMINI_API_KEY=

# 商汤日日新 (SenseNova) API Key
SENSENOVA_API_KEY=

# 英伟达 NVIDIA API Key
NVIDIA_API_KEY=